{
  "name": "recipedia",
  "version": "2.46.0",
  "packageManager": "npm@10.9.3",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "dev:android": "expo run:android",
    "dev:ios": "expo run:ios",
    "dev:clean": "npx expo start --clear",
    "build:test:android": "eas build --local --profile maestro --platform android --non-interactive",
    "build:test:ios": "eas build --local --profile maestro --platform ios --non-interactive",
    "build:prod:android": "eas build --local --profile production --platform android --non-interactive",
    "build:prod:ios": "eas build --local --profile production --platform ios --non-interactive",
    "build:perf:android": "eas build --local --profile performance --platform android --non-interactive",
    "build:perf:ios": "eas build --local --profile performance --platform ios --non-interactive",
    "build:clean": "rm -rf android/app/build ios/build .expo",
    "install:android": "adb install *.apk && rm -f *.apk",
    "install:ios": "xcrun simctl install booted *.app",
    "submit:android": "eas submit --platform android --path ./build-*.aab --non-interactive",
    "submit:ios": "eas submit --platform ios --path ./build-*.ipa --non-interactive",
    "submit:android:latest": "eas submit --platform android --latest --non-interactive",
    "submit:ios:latest": "eas submit --platform ios --latest --non-interactive",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --config jest.config.js tests/unit",
    "test:unit:watch": "jest --watchAll --silent --config jest.config.js tests/unit",
    "test:unit:coverage": "jest --reporters=default --coverage --reporters=jest-junit --config jest.config.js tests/unit",
    "test:unit:fail-only": "jest --silent --onlyFailures --config jest.config.js tests/unit",
    "test:integration": "jest --config jest.config.js tests/integration",
    "boot:ios-simulator": "xcrun simctl boot 'iPhone SE (3rd generation)' || echo 'Simulator may already be booted'",
    "workflow:build-test:ios": "npm run build:test:ios && npm run boot:ios-simulator && npm run install:ios && npm run test:e2e:ios",
    "test:perf": "reassure",
    "test:perf:baseline": "reassure --baseline",
    "test:scripts": "node --test .github/scripts/*.test.mjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "tsc --noEmit",
    "expo:doctor": "npx expo-doctor",
    "knip:check": "knip",
    "quality": "npm run lint && npm run format:check && npm run typecheck && npm run knip:check && npm run expo:doctor",
    "docs:build": "typedoc",
    "docs:clean": "rm -rf docs/",
    "workflow:build-install::android": "npm run build:test:android && npm run install:android",
    "workflow:quality": "npm run quality && npm run test:unit:coverage",
    "release": "semantic-release",
    "security:audit": "npm audit --audit-level=moderate",
    "prepare": "husky",
    "postinstall": "patch-package",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-ml-kit/text-recognition"
        ],
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": [
        "react-native-webview"
      ]
    }
  },
  "lint-staged": {
    "{src,tests}/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "{src,tests}/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "5.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.2.0",
    "@react-native-ml-kit/text-recognition": "~1.5.2",
    "@react-navigation/bottom-tabs": "~6.5.8",
    "@react-navigation/native": "~6.1.7",
    "@react-navigation/native-stack": "~6.9.13",
    "@react-navigation/stack": "~6.3.17",
    "@shopify/flash-list": "2.0.2",
    "eslint-config-expo": "~56.0.4",
    "expo": "~56.0.16",
    "expo-asset": "~56.0.17",
    "expo-background-task": "~56.0.22",
    "expo-build-properties": "~56.0.23",
    "expo-clipboard": "~56.0.4",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.23",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.22",
    "expo-localization": "~56.0.6",
    "expo-mail-composer": "~56.0.4",
    "expo-splash-screen": "~56.0.13",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.22",
    "html-entities": "2.6.0",
    "i18next": "^25.5.2",
    "i18next-resources-to-backend": "^1.2.1",
    "minisearch": "7.2.0",
    "numeric-quantity": "2.1.0",
    "react": "19.2.3",
    "react-compiler-runtime": "1.0.0",
    "react-dom": "19.2.3",
    "react-hook-form": "7.81.0",
    "react-i18next": "^15.5.1",
    "react-native": "0.85.3",
    "react-native-copilot": "3.3.3",
    "react-native-extended-stylesheet": "~0.12.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-image-crop-picker": "0.51.1",
    "react-native-logs": "^5.3.0",
    "react-native-paper": "5.15.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1",
    "zod": "4.4.3"
  },
  "resolutions": {
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "overrides": {
    "undici": "^6.24.1",
    "zod-validation-error": "^4.0.0"
  },
  "private": true,
  "devDependencies": {
    "@babel/preset-env": "~7.28.3",
    "@babel/preset-typescript": "~7.27.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/eslint-config": "^3.2.0",
    "@react-native/jest-preset": "0.85.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.5",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "^14.0.1",
    "@testing-library/react-native": "13.3.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "babel-jest": "~30.1.2",
    "babel-plugin-module-resolver": "~5.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "better-sqlite3": "~11.10.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "56.0.5",
    "jest-junit": "^16.0.0",
    "knip": "6.27.0",
    "lint-staged": "16.4.0",
    "metro-react-native-babel-preset": "~0.77.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.9.5",
    "pyodide": "0.28.3",
    "reassure": "1.5.1",
    "semantic-release": "25.0.8",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "varvara-typedoc-theme": "0.3.9"
  }
}
